# =============================================================================
# PrigeeX frontend environment
# Copy to .env.local and fill in.
#
# NOTE: Contract addresses live in packages/dex-config.ts (version-controlled).
# Subgraph queries are proxied through /api/subgraph/* so private URLs and
# tokens never reach the browser - set the server-only vars below.
# =============================================================================

# WalletConnect Cloud project id (required for the WalletConnect connector).
# Create one at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# RPC endpoint (server-only - never sent to the browser).
# The browser routes all JSON-RPC calls through /api/rpc which reads this var.
# Defaults to the local Anvil fork at localhost:8545 when unset.
RPC_URL=http://localhost:8545

# =============================================================================
# Subgraph endpoints (server-only - never sent to the browser)
# Leave unset to fall back to a local graph-node at localhost:8000.
# =============================================================================

# Goldsky (or any hosted Graph node) private URLs for the three subgraphs.
SUBGRAPH_URL_V3=
SUBGRAPH_URL_V2=
SUBGRAPH_URL_PROTOCOL=

# Bearer token for private Goldsky subgraphs (single token for all three).
SUBGRAPH_BEARER_TOKEN=
