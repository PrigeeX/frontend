# =============================================================================
# PrigeeX frontend environment
# Copy to .env.local and fill in.
#
# NOTE: Contract addresses and subgraph URLs are NOT here - they live in a single
# version-controlled config file: packages/dex-config.ts. Edit that file to point
# the dApp at a different deployment (local Anvil fork / Sepolia / mainnet).
#
# Only the two values below are environment-specific.
# =============================================================================

# WalletConnect Cloud project id (required for the WalletConnect connector).
# Create one at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# RPC endpoint. Defaults to the local Anvil fork of Arbitrum Sepolia
# (http://localhost:8545) when unset. Override to use a public node.
NEXT_PUBLIC_RPC_URL=http://localhost:8545
